API_FOOTBALL_KEY=your_api_football_key_here

# OBRIGATÓRIO — mínimo 32 caracteres, string aleatória longa
# Gera uma com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=MUDA_ISTO_PARA_UMA_STRING_ALEATORIA_LONGA_MIN_32_CHARS
PORT=3000
BASE_URL=http://localhost:3000

# SMTP para envio de emails (recuperação de password)
# Se não configurado, o link de reset é mostrado no console (apenas em desenvolvimento)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=o.teu@gmail.com
SMTP_PASS=app-password-aqui
SMTP_FROM=A Bola Maya <noreply@abolamaya.com>

# OAuth — optional, leave blank to disable each provider
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

